    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.19.0",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.11",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",

{
  "name": "@eazmenu/server",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx index.ts",
    "build": "npx esbuild index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./drizzle.config.ts",
    "db:push": "drizzle-kit push --force --config=./drizzle.config.ts",
    "db:seed-demo": "tsx scripts/seed-demo.ts",
    "db:seed-analytics": "tsx scripts/seed-analytics.ts",
    "db:init": "tsx db/init-standalone.ts"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",

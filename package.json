    "@supabase/supabase-js": "^2.105.1",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "archiver": "^7.0.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
